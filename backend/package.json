{
  "name": "akashi-backend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:pull": "drizzle-kit pull",
    "db:push": "drizzle-kit push",
    "test": "vitest run -c vitest.config.ts && vitest run -c vitest.config.integration.ts",
    "test:unit": "vitest run -c vitest.config.ts",
    "test:int": "vitest run -c vitest.config.integration.ts",
    "test:e2e": "vitest run -c vitest.config.e2e.ts",
    "test:ci": "vitest run -c vitest.config.ts",
    "test:watch": "vitest -c vitest.config.ts",
    "test:perf": "tsx scripts/load-test.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.0",
    "@drift-labs/sdk": "^2.156.0-beta.0",
    "@drift-labs/vaults-sdk": "^0.9.266",
    "@exponent-labs/exponent-sdk": "^0.9.7",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.2.1",
    "@jup-ag/lend": "^0.1.9",
    "@kamino-finance/klend-sdk": "^7.3.21",
    "@kamino-finance/kswap-sdk": "^2.4.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@solana-program/compute-budget": "^0.15.0",
    "@solana/addresses": "^2.1.1",
    "@solana/kit": "^6.5.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "bn.js": "^5.2.3",
    "decimal.js": "^10.6.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.4",
    "fastify": "^5.2.1",
    "fastify-type-provider-zod": "^4.0.2",
    "node-cron": "^3.0.3",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "qrcode": "^1.5.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/autocannon": "^7.12.7",
    "@types/bn.js": "^5.2.0",
    "@types/node": "^22.12.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.11",
    "@types/qrcode": "^1.5.6",
    "autocannon": "^8.0.0",
    "drizzle-kit": "^0.30.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
