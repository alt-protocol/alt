# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Platform AI key (used when user has no BYOK key)
PLATFORM_ANTHROPIC_KEY=your-anthropic-api-key

# Backend API
AKASHI_API_URL=http://localhost:8001

# Database (shared with backend)
DATABASE_URL=postgresql://localhost:5432/alt

# Encryption key for storing user API keys (32 bytes hex)
ENCRYPTION_KEY=your-32-byte-hex-key

# Webhook mode (production — leave empty for local polling)
# WEBHOOK_URL=https://your-bot.railway.app
# PORT=3000
# WEBHOOK_SECRET=your-random-secret
