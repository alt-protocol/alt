# Backend API base URL (defaults to http://localhost:8001 if unset)
# Production: set to your Railway backend URL (e.g. https://backend-production-xxxx.up.railway.app)
NEXT_PUBLIC_API_URL=http://localhost:8001

# Helius RPC endpoint for Solana on-chain reads (wallet balances, tx submission)
NEXT_PUBLIC_HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here
